        ],
        "responses": {
          "200": {
            "description": "Tra ve danh sach phim",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Them phim moi",
        "tags": [
          "Movies"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MovieInput"
              },
              "examples": {
                "newMovie": {
                  "summary": "Phim moi",
                  "value": {
                    "title": "Interstellar",
                    "director": "Christopher Nolan"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Da them phim",
