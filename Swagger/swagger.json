          "Movies"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 1,
            "description": "ID cua phim can xoa"
          }
        ],
        "responses": {
          "204": {
            "description": "Da xoa phim"
