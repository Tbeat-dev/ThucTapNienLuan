  "paths": {
    "/health": {
      "get": {
        "summary": "Kiem tra tinh trang hoat dong cua server",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Server hoat dong binh thuong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
